<?xml version="1.0" encoding="utf-8"?>
<!-- Card individual de produto — usado no RecyclerView da LojaActivity -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardProduto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#141414"
    app:cardCornerRadius="18dp"
    app:cardElevation="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Imagem do produto -->
        <ImageView
            android:id="@+id/ivProdutoImagem"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:scaleType="centerCrop"
            android:background="#1E1E1E"
            android:src="@android:drawable/ic_menu_gallery"
            app:cornerRadius="10dp" />

        <!-- Nome e preço -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tvProdutoNome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nome do Item"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰 "
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvProdutoPreco"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="500 GC"
                    android:textColor="#FFD700"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- Botão Comprar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnComprar"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="COMPRAR"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#0D0D0D"
            app:backgroundTint="#00FF7F"
            app:cornerRadius="10dp"
            app:rippleColor="#40FFFFFF" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
